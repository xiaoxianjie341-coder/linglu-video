{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "jsx": "react-jsx",
    "noEmit": false,
    "incremental": false,
    "plugins": []
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", ".next", "app", "components", "lib"]
}
